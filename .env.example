# Discord Bot Token (https://discord.com/developers/applications)
DISCORD_TOKEN=ここにトークンを貼る

# 開発用: 即時反映させたいギルド(サーバー)ID。空ならグローバル同期(反映に時間がかかる)
DEV_GUILD_ID=

# 管理者の Discord ユーザーID をカンマ区切りで(例: 123,456)
ADMIN_IDS=

# DB ファイルのパス
DB_PATH=casino.db

# 通貨単位の表示名
CURRENCY_NAME=チップ
CURRENCY_EMOJI=🪙

# 有効ゲーム(カンマ区切り)。未設定または空なら全部有効。
# 利用可能: slot, chinchiro, chohan, holdem, draw, hilo, blackjack
# 例: PVE のみ → ENABLED_GAMES=slot,chinchiro,hilo,blackjack
ENABLED_GAMES=
