# Discord Bot Token (https://discord.com/developers/applications)
DISCORD_TOKEN=ここにトークンを貼る

# 開発用: 即時反映させたいギルド(サーバー)ID。空ならグローバル同期(反映に時間がかかる)
DEV_GUILD_ID=

# 管理者の Discord ユーザーID をカンマ区切りで(例: 123,456)
ADMIN_IDS=

# DB ファイルのパス
DB_PATH=casino.db

# 通貨単位の表示名
CURRENCY_NAME=チップ
CURRENCY_EMOJI=🪙

# 有効ゲーム(カンマ区切り)。未設定または空なら全部有効。
# 利用可能: slot, chinchiro, chohan, holdem, draw, hilo, blackjack
# 例: PVE のみ → ENABLED_GAMES=slot,chinchiro,hilo,blackjack
ENABLED_GAMES=

# ===== 両替: 外部通貨API連携(オプション) =====
# 未設定 or none なら手動承認モードのまま。API実装が用意できたら driver を指定して
# URL/KEY を入れると、両替申請が自動完結する。
# EXCHANGE_AUTO_DRIVER=none
# EXCHANGE_AUTO_API_URL=https://example.invalid/api/currency
# EXCHANGE_AUTO_API_KEY=
# EXCHANGE_AUTO_TIMEOUT_SEC=10
